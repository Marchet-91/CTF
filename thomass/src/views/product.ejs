<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>thomass</title>
		<link href="/output.css" rel="stylesheet" />
	</head>
	<body class="min-h-screen flex flex-col">
		<%- include('navbar') %>
		<main class="grow py-10 px-4">
			<div class="mx-auto max-w-7xl w-full grid grid-cols-[66%_1fr] gap-6">
				<div>
					<h1 class="text-4xl font-bold"><%= product.name %></h1>
					<img src="<%= product.image %>" class="w-full h-96 object-contain mt-6" />
					<div class="bg-neutral-100 grid grid-cols-3 items-center p-4 mt-4">
						<div class="font-bold text-lg">Sound samples</div>
						<button
							onclick="play()"
							class="cursor-pointer text-black hover:text-sky-700 transition-colors duration-100 justify-self-center">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="size-6">
								<path
									fill-rule="evenodd"
									d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z"
									clip-rule="evenodd" />
							</svg>
						</button>
						<button
							class="cursor-pointer text-black hover:text-sky-700 transition-colors duration-100 justify-self-end">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="size-6">
								<path
									d="M13.5 4.06c0-1.336-1.616-2.005-2.56-1.06l-4.5 4.5H4.508c-1.141 0-2.318.664-2.66 1.905A9.76 9.76 0 0 0 1.5 12c0 .898.121 1.768.35 2.595.341 1.24 1.518 1.905 2.659 1.905h1.93l4.5 4.5c.945.945 2.561.276 2.561-1.06V4.06ZM18.584 5.106a.75.75 0 0 1 1.06 0c3.808 3.807 3.808 9.98 0 13.788a.75.75 0 0 1-1.06-1.06 8.25 8.25 0 0 0 0-11.668.75.75 0 0 1 0-1.06Z" />
								<path
									d="M15.932 7.757a.75.75 0 0 1 1.061 0 6 6 0 0 1 0 8.486.75.75 0 0 1-1.06-1.061 4.5 4.5 0 0 0 0-6.364.75.75 0 0 1 0-1.06Z" />
							</svg>
						</button>
					</div>
					<div class="mt-2 text-lg"><%= product.description %></div>
				</div>
				<div>
					<div class="flex">
						<div class="font-bold text-5xl mt-2 mr-2">&euro;</div>
						<div class="font-bold text-7xl"><%= product.price %></div>
					</div>
					<div class="text-sm mt-1">All prices incl. VAT</div>
					<div class="text-green-500 font-medium mt-3">In stock</div>
					<form method="POST">
						<button
							class="block w-full cursor-pointer bg-black text-white font-bold rounded-full text-center text-xl uppercase py-3 px-4 mt-6">
							Add to cart
						</button>
					</form>
				</div>
			</div>
		</main>

		<script>
			function play() {
				alert('Please, not during the competition...');
			}
		</script>
	</body>
</html>
